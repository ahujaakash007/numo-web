# Numo web funnel — env vars
# Copy to .env.local for local dev, or set in Railway service variables.

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=https://numo-backend-production.up.railway.app/api/v1

# Firebase Web app config (Project settings → General → Your apps → Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=numo-ai-1a675.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=numo-ai-1a675
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=numo-ai-1a675.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Meta Pixel ID (Events Manager → Dataset → Settings)
NEXT_PUBLIC_META_PIXEL_ID=
